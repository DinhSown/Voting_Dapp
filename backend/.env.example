# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Blockchain ──────────────────────────────────────────────────────────────
# Local Hardhat node: http://127.0.0.1:8545
# Oasis Sapphire Testnet: https://testnet.sapphire.oasis.io
RPC_URL=https://testnet.sapphire.oasis.io

# Private key CÓ tiền tố 0x — dùng để backend whitelist ví on-chain
# Local: dùng account #0 của Hardhat: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Testnet: private key ví thật (cần có TEST token để trả gas)
PRIVATE_KEY=0x_your_private_key_with_0x_prefix

# Điền sau khi chạy: npx hardhat run scripts/deploy.ts --network <network>
CONTRACT_ADDRESS=0x_contract_address_after_deploy

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── Authentication ──────────────────────────────────────────────────────────
# Chuỗi ngẫu nhiên >= 32 ký tự. Ví dụ: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_min_32_chars_change_in_production

# ─── Admin ───────────────────────────────────────────────────────────────────
# Key để gọi các endpoint /api/admin/* (dùng header x-admin-key)
ADMIN_API_KEY=your_admin_api_key_change_in_production

# Địa chỉ ví (0x...) được cấp quyền admin khi đăng nhập qua MetaMask
ADMIN_WALLET=0x_your_admin_wallet_address

# ─── SMTP (tuỳ chọn) ─────────────────────────────────────────────────────────
# Bỏ trống toàn bộ SMTP để dùng mock mode — OTP sẽ log ra console backend
# Gmail: tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
MAIL_FROM=your@gmail.com

# ─── Twilio SMS (tuỳ chọn) ────────────────────────────────────────────────────
# Bỏ trống nếu không dùng SMS OTP
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
