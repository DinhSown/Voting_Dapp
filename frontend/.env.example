# ─── Contract ────────────────────────────────────────────────────────────────
# Phải khớp với CONTRACT_ADDRESS trong backend/.env
# Điền sau khi deploy contract
VITE_CONTRACT_ADDRESS=0x_contract_address_after_deploy

# ─── Backend ─────────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:3001

# ─── Admin ───────────────────────────────────────────────────────────────────
# Phải khớp với ADMIN_API_KEY trong backend/.env
VITE_ADMIN_API_KEY=your_admin_api_key_change_in_production
